# Load profile
source /etc/profile #
module load openmpi/4.1.6_gcc-13.3.0 #

# Execute full pipeline, but writing data to $TMPDIR for better performance
make run OUT_DIR=$TMPDIR #

# Create folder for the job
mkdir -p $SGE_O_WORKDIR/results_archive/$JOB_ID #

# Copy results from $TMPDIR to working directory
cp -r $TMPDIR/data $SGE_O_WORKDIR/results_archive/$JOB_ID/ #